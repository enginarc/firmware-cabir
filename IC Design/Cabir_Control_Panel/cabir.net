(net-list
  (design
    (source "cabir.kicad_sch")
    (date "2026-04-13")
    (tool "KiCad 9.0")
    (sheet (number "1") (name "Cabir Heat Plate Controller") (tstamps "root"))
  )

  ;; ═══════════════════════════════════════════════════════════════
  ;; COMPONENT LIST
  ;; ═══════════════════════════════════════════════════════════════

  (components

    ;; ── Fuses & Thermal Protection ──────────────────────────────

    (comp (ref "F1")
      (value "3A 250V Fast-blow")
      (footprint "Fuse:Fuseholder_Cylinder_5x20mm_Horizontal_Open_Enclosed")
      (description "Mains overcurrent protection, 5x20mm glass fuse")
      (fields (field (name "MPN") "5x20mm 3A Fast-blow")
              (field (name "Voltage") "250V AC")
              (field (name "Zone") "HV-AC"))
    )

    (comp (ref "TF1")
      (value "185°C 250V 15A")
      (footprint "Fuse:Fuse_Radial_D5.0mm_P5.0mm")
      (description "One-shot thermal fuse — catastrophic overheat cutoff")
      (fields (field (name "MPN") "TF 185C 250V 15A")
              (field (name "Voltage") "250V AC")
              (field (name "Zone") "HV-AC"))
    )

    (comp (ref "F2")
      (value "0.5A 250V Fast-blow")
      (footprint "Fuse:Fuseholder_Cylinder_5x20mm_Horizontal_Open_Enclosed")
      (description "HLK-10M05 branch fuse — F1 at 3A too coarse to protect PSU alone")
      (fields (field (name "MPN") "5x20mm 0.5A Fast-blow")
              (field (name "Voltage") "250V AC")
              (field (name "Zone") "HV-AC"))
    )

    (comp (ref "MOV1")
      (value "10D561 275V Varistor")
      (footprint "Varistor:RV_Disc_D10.5mm_W3.5mm_P7.5mm")
      (description "MOV surge suppression across L-N, clamping ~910V at 50A")
      (fields (field (name "MPN") "10D561")
              (field (name "Vrms") "275V AC")
              (field (name "Zone") "HV-AC"))
    )

    (comp (ref "C7")
      (value "100nF 275V X2")
      (footprint "Capacitor_THT:C_Rect_L13.0mm_W6.0mm_P10.00mm")
      (description "X2 safety capacitor across L-N, differential EMI filter")
      (fields (field (name "Dielectric") "X2 MPP")
              (field (name "Voltage") "275V AC")
              (field (name "Zone") "HV-AC"))
    )

    (comp (ref "L1")
      (value "10mH Common-mode choke")
      (footprint "Inductor_THT:L_Toroid_Horizontal_D12.0mm_P12.5mm")
      (description "Common-mode choke on L and N lines to HLK — per Hi-Link appnote")
      (fields (field (name "Inductance") "10mH")
              (field (name "Irated") "1A")
              (field (name "Zone") "HV-AC"))
    )

    (comp (ref "C8")
      (value "220µF 10V")
      (footprint "Capacitor_THT:CP_Radial_D8.0mm_P3.50mm")
      (description "HLK-10M05 +5V output bulk capacitor — per Hi-Link appnote")
      (fields (field (name "Dielectric") "Electrolytic")
              (field (name "Voltage") "10V")
              (field (name "Zone") "LV-DC"))
    )

    ;; ── Thermal Switches ────────────────────────────────────────

    (comp (ref "KSD1")
      (value "KSD301 NC 70°C")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical")
      (description "Bimetallic NC thermal switch — auto-reset at ~65°C, opens at 70°C, series AC line")
      (fields (field (name "MPN") "KSD301 NC 70C")
              (field (name "Voltage") "250V AC 10A")
              (field (name "Zone") "HV-AC"))
    )

    (comp (ref "KSD2")
      (value "KSD301 NO 60°C")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical")
      (description "Bimetallic NO thermal switch — closes at 60°C, GPIO warning signal")
      (fields (field (name "MPN") "KSD301 NO 60C")
              (field (name "Voltage") "50V 1A")
              (field (name "Zone") "LV-Signal"))
    )

    ;; ── AC-DC Power Supply ───────────────────────────────────────

    (comp (ref "PS1")
      (value "HLK-10M05")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical")
      (description "Hi-Link isolated AC-DC module 220V→5V 2A 10W")
      (fields (field (name "MPN") "HLK-10M05")
              (field (name "Vin") "85-265V AC")
              (field (name "Vout") "5V DC 2A")
              (field (name "Zone") "HV-AC/LV-DC boundary"))
    )

    ;; ── LDO Voltage Regulator ────────────────────────────────────

    (comp (ref "U1")
      (value "TLV1117-33IDCYR")
      (footprint "Package_TO_SOT_SMD:SOT-223-3_TabPin2")
      (description "Texas Instruments LDO 5V→3.3V 800mA, industrial -40°C to +125°C")
      (fields (field (name "MPN") "TLV1117-33IDCYR")
              (field (name "Package") "SOT-223-4")
              (field (name "Vin_max") "15V")
              (field (name "Vout") "3.3V")
              (field (name "Iout") "800mA"))
    )

    ;; ── LDO Bypass Capacitors ────────────────────────────────────

    (comp (ref "C1")
      (value "10µF 10V")
      (footprint "Capacitor_SMD:C_1206_3216Metric")
      (description "LDO U1 input bulk capacitor — electrolytic or ceramic X5R/X7R")
      (fields (field (name "Dielectric") "X5R")
              (field (name "Voltage") "10V"))
    )

    (comp (ref "C2")
      (value "10µF 10V")
      (footprint "Capacitor_SMD:C_1206_3216Metric")
      (description "LDO U1 output bulk capacitor")
      (fields (field (name "Dielectric") "X5R")
              (field (name "Voltage") "10V"))
    )

    ;; ── Microcontroller ──────────────────────────────────────────

    (comp (ref "U2")
      (value "ESP32-S3 Super Mini")
      (footprint "ESP32-S3-SuperMini:ESP32-S3-SuperMini")
      (description "Espressif ESP32-S3 Super Mini module — BLE, dual-core, ADC, SPI")
      (fields (field (name "MPN") "ESP32-S3 Super Mini")
              (field (name "Flash") "4MB")
              (field (name "VIN_max") "5.5V"))
    )

    ;; ── ESP32 Decoupling Capacitors ──────────────────────────────

    (comp (ref "C3")
      (value "100nF 10V")
      (footprint "Capacitor_SMD:C_1206_3216Metric")
      (description "ESP32 3.3V supply decoupling cap 1 — place close to VCC pin")
      (fields (field (name "Dielectric") "X7R"))
    )

    (comp (ref "C4")
      (value "100nF 10V")
      (footprint "Capacitor_SMD:C_1206_3216Metric")
      (description "ESP32 3.3V supply decoupling cap 2")
      (fields (field (name "Dielectric") "X7R"))
    )

    ;; ── Solid State Relay ────────────────────────────────────────

    (comp (ref "SSR1")
      (value "SSR-40-DA")
      (footprint "Relay_SolidState:Relay_SolidState_Crydom_CX")
      (description "Solid state relay 40A, 3-32V DC control, 24-480V AC load, zero-cross")
      (fields (field (name "MPN") "SSR-40-DA")
              (field (name "Ctrl_Vin") "3-32V DC")
              (field (name "Load") "24-480V AC 40A")
              (field (name "Zone") "HV-AC/LV-DC boundary"))
    )

    ;; ── SSR Drive — NPN Transistor ───────────────────────────────

    (comp (ref "Q1")
      (value "MMBT2222A")
      (footprint "Package_TO_SOT_SMD:SOT-23")
      (description "NPN transistor SOT-23 — drives SSR control input from ESP32 3.3V GPIO")
      (fields (field (name "MPN") "MMBT2222A")
              (field (name "Vceo") "40V")
              (field (name "Ic") "600mA")
              (field (name "Package") "SOT-23"))
    )

    ;; ── SSR Drive — Resistors ─────────────────────────────────────

    (comp (ref "R1")
      (value "220Ω")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "SSR control current limiter — 5V rail to SSR Ctrl+, limits to ~16mA")
      (fields (field (name "Power") "0.25W")
              (field (name "Tolerance") "1%"))
    )

    (comp (ref "R2")
      (value "1KΩ")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "NPN Q1 base current limiter from ESP32 GPIO4 — limits base current to ~2.6mA")
      (fields (field (name "Power") "0.125W")
              (field (name "Tolerance") "1%"))
    )

    ;; ── SSR Control Protection Diode ─────────────────────────────

    (comp (ref "D1")
      (value "1N4148WS")
      (footprint "Diode_SMD:D_SOD-323")
      (description "Fast signal diode across SSR control input — reverse polarity protection")
      (fields (field (name "MPN") "1N4148WS")
              (field (name "Vr") "75V")
              (field (name "If") "150mA")
              (field (name "Package") "SOD-323"))
    )

    ;; ── Plate NTC Thermistor ──────────────────────────────────────

    (comp (ref "RT1")
      (value "10K NTC 3950K")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "SMD 1206 NTC thermistor — mounted on aluminium plate edge, primary control sensor")
      (fields (field (name "MPN") "10K SMD 1206 NTC 3950K")
              (field (name "R25") "10KΩ")
              (field (name "Beta") "3950K"))
    )

    ;; ── Plate NTC Voltage Divider ────────────────────────────────

    (comp (ref "R3")
      (value "10KΩ")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "Plate NTC voltage divider upper resistor — 3.3V to ADC midpoint")
      (fields (field (name "Power") "0.125W")
              (field (name "Tolerance") "1%"))
    )

    ;; ── Plate ADC Input Protection ───────────────────────────────

    (comp (ref "R7")
      (value "100Ω")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "Plate NTC ADC input series protection resistor — ESD and current limiting")
      (fields (field (name "Power") "0.125W")
              (field (name "Tolerance") "5%"))
    )

    ;; ── Plate ADC Filter Capacitor ───────────────────────────────

    (comp (ref "C5")
      (value "100nF 10V")
      (footprint "Capacitor_SMD:C_1206_3216Metric")
      (description "Plate NTC ADC RC filter cap — forms RC filter with R7, Fc≈16kHz")
      (fields (field (name "Dielectric") "X7R"))
    )

    ;; ── External (Liquid) NTC Voltage Divider ───────────────────

    (comp (ref "R4")
      (value "10KΩ")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "Liquid NTC voltage divider upper resistor — 3.3V to ADC midpoint")
      (fields (field (name "Power") "0.125W")
              (field (name "Tolerance") "1%"))
    )

    ;; ── Liquid ADC Input Protection ──────────────────────────────

    (comp (ref "R8")
      (value "100Ω")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "Liquid NTC ADC input series protection resistor")
      (fields (field (name "Power") "0.125W")
              (field (name "Tolerance") "5%"))
    )

    ;; ── Liquid ADC Filter Capacitor ──────────────────────────────

    (comp (ref "C6")
      (value "100nF 10V")
      (footprint "Capacitor_SMD:C_1206_3216Metric")
      (description "Liquid NTC ADC RC filter cap — forms RC filter with R8")
      (fields (field (name "Dielectric") "X7R"))
    )

    ;; ── KSD301 NO Warning Signal Pull-up ─────────────────────────

    (comp (ref "R5")
      (value "10KΩ")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "KSD301 NO pull-up resistor to 3.3V — GPIO reads LOW when KSD301 NO closes at 60°C")
      (fields (field (name "Power") "0.125W")
              (field (name "Tolerance") "5%"))
    )

    ;; ── Display Backlight Current Limiter ────────────────────────

    (comp (ref "R6")
      (value "47Ω")
      (footprint "Resistor_SMD:R_1206_3216Metric")
      (description "ST7789V display backlight LED current limiter — GPIO7 to BL pin")
      (fields (field (name "Power") "0.25W")
              (field (name "Tolerance") "5%"))
    )

    ;; ── Display ──────────────────────────────────────────────────

    (comp (ref "LCD1")
      (value "ST7789V 2in TFT")
      (footprint "Connector_FFC-FPC:Hirose_FH12-8S-0.5SH_1x08-1MP_P0.5mm_Horizontal")
      (description "2.0 inch TFT LCD 240x320 RGB565, SPI interface, ST7789V controller")
      (fields (field (name "MPN") "2.0in TFT ST7789V 240x320")
              (field (name "Interface") "4-wire SPI")
              (field (name "Vcc") "3.3V"))
    )

    ;; ── Fan ──────────────────────────────────────────────────────

    (comp (ref "FAN1")
      (value "PF4010D5HSL")
      (footprint "Connector_JST:JST_XH_B2B-XH-A_1x02_P2.50mm_Vertical")
      (description "Sunon 40x40x10mm brushless fan 5V 0.15A — electronics bay ventilation")
      (fields (field (name "MPN") "PF4010D5HSL")
              (field (name "Vcc") "5V")
              (field (name "Icc") "150mA"))
    )

    ;; ── PTC Heater ───────────────────────────────────────────────

    (comp (ref "PTC1")
      (value "PTC 500W 220V")
      (footprint "Connector_JST:JST_XH_B2B-XH-A_1x02_P2.50mm_Vertical")
      (description "PTC ceramic heater 500W 220V AC — self-limiting, mounted under aluminium plate")
      (fields (field (name "Power") "500W")
              (field (name "Voltage") "220V AC")
              (field (name "Tmax") "~290°C self-limit")
              (field (name "Zone") "HV-AC"))
    )

    ;; ── Connectors ───────────────────────────────────────────────

    (comp (ref "J1")
      (value "Mains Inlet L-N-PE")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical")
      (description "AC mains input — Live, Neutral, Protective Earth from Schuko inlet")
      (fields (field (name "Zone") "HV-AC")
              (field (name "Note") "Schuko CEE7/4 — L/N unpolarised, PE always pin 3"))
    )

    (comp (ref "J2")
      (value "SSR Load Out 2-pin")
      (footprint "Connector_JST:JST_XH_B2B-XH-A_1x02_P2.50mm_Vertical")
      (description "SSR T2 output to PTC heater Live terminal — high voltage, H-class sleeved")
      (fields (field (name "Zone") "HV-AC"))
    )

    (comp (ref "J3")
      (value "KSD301 NC 2-pin")
      (footprint "Connector_JST:JST_XH_B2B-XH-A_1x02_P2.50mm_Vertical")
      (description "KSD301 NC 70°C — series on AC Live line, auto-reset thermal cutoff")
      (fields (field (name "Zone") "HV-AC"))
    )

    (comp (ref "J4")
      (value "KSD301 NO 2-pin")
      (footprint "Connector_JST:JST_XH_B2B-XH-A_1x02_P2.50mm_Vertical")
      (description "KSD301 NO 60°C — warning signal only, low-voltage signal circuit")
      (fields (field (name "Zone") "LV-Signal"))
    )

    (comp (ref "J5")
      (value "Pogo-NTC 2-pin")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical")
      (description "External liquid NTC pogo pin connector — 2-pin magnetic pogo, detachable probe")
      (fields (field (name "Note") "2x pogo pin + 2x N34 Neodymium magnet self-aligning connector"))
    )

    (comp (ref "J6")
      (value "Fan 2-pin JST-XH")
      (footprint "Connector_JST:JST_XH_B2B-XH-A_1x02_P2.50mm_Vertical")
      (description "40mm fan power connector — 5V and GND")
    )

    (comp (ref "J7")
      (value "Display 8-pin")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x08_P2.54mm_Vertical")
      (description "ST7789V display module connector — VCC GND SCK MOSI CS DC RST BL")
    )

    (comp (ref "J8")
      (value "ESP32 UART 4-pin")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical")
      (description "Debug/programming header — GND 3.3V TX RX (optional, can be omitted in production)")
    )

  ) ;; end components

  ;; ═══════════════════════════════════════════════════════════════
  ;; NETS
  ;; ═══════════════════════════════════════════════════════════════

  (nets

    ;; ── High-voltage AC nets ─────────────────────────────────────

    (net (name "MAINS_L")
      (node (ref "J1")    (pin "1") (pintype "passive"))
      (node (ref "F1")    (pin "1") (pintype "passive"))
    )

    (net (name "MAINS_L_FUSED")
      (node (ref "F1")    (pin "2") (pintype "passive"))
      (node (ref "TF1")   (pin "1") (pintype "passive"))
      (node (ref "MOV1")  (pin "1") (pintype "passive"))
      (node (ref "C7")    (pin "1") (pintype "passive"))
      (node (ref "F2")    (pin "1") (pintype "passive"))
    )

    (net (name "HLK_L_IN")
      (node (ref "F2")    (pin "2") (pintype "passive"))
      (node (ref "L1")    (pin "1") (pintype "passive"))
    )

    (net (name "HLK_L_FILTERED")
      (node (ref "L1")    (pin "2") (pintype "passive"))
      (node (ref "PS1")   (pin "1") (pintype "input"))
    )

    (net (name "HLK_N_IN")
      (node (ref "L1")    (pin "3") (pintype "passive"))
      (node (ref "PS1")   (pin "2") (pintype "input"))
    )

    (net (name "MAINS_L_SAFE")
      (node (ref "TF1")   (pin "2") (pintype "passive"))
      (node (ref "J3")    (pin "1") (pintype "passive"))
    )

    (net (name "KSD1_OUT")
      (node (ref "J3")    (pin "2") (pintype "passive"))
      (node (ref "SSR1")  (pin "1") (pintype "input"))
    )

    (net (name "SSR_T2_OUT")
      (node (ref "SSR1")  (pin "2") (pintype "output"))
      (node (ref "J2")    (pin "1") (pintype "passive"))
    )

    (net (name "MAINS_N")
      (node (ref "J1")    (pin "2") (pintype "passive"))
      (node (ref "MOV1")  (pin "2") (pintype "passive"))
      (node (ref "C7")    (pin "2") (pintype "passive"))
      (node (ref "L1")    (pin "4") (pintype "passive"))
      (node (ref "J2")    (pin "2") (pintype "passive"))
    )

    (net (name "PE")
      (node (ref "J1")    (pin "3") (pintype "passive"))
      (node (ref "SSR1")  (pin "5") (pintype "passive"))
    )

    ;; ── DC power nets ────────────────────────────────────────────

    (net (name "+5V")
      (node (ref "PS1")   (pin "3") (pintype "output"))
      (node (ref "U1")    (pin "1") (pintype "input"))
      (node (ref "C1")    (pin "1") (pintype "passive"))
      (node (ref "R1")    (pin "1") (pintype "passive"))
      (node (ref "FAN1")  (pin "1") (pintype "passive"))
      (node (ref "J6")    (pin "1") (pintype "passive"))
      (node (ref "U2")    (pin "2") (pintype "power_in"))
      (node (ref "C8")    (pin "1") (pintype "passive"))
    )

    (net (name "+3V3")
      (node (ref "U1")    (pin "2") (pintype "output"))
      (node (ref "C2")    (pin "1") (pintype "passive"))
      (node (ref "C3")    (pin "1") (pintype "passive"))
      (node (ref "C4")    (pin "1") (pintype "passive"))
      (node (ref "R3")    (pin "1") (pintype "passive"))
      (node (ref "R4")    (pin "1") (pintype "passive"))
      (node (ref "R5")    (pin "1") (pintype "passive"))
      (node (ref "LCD1")  (pin "1") (pintype "power_in"))
      (node (ref "J7")    (pin "1") (pintype "passive"))
      (node (ref "J8")    (pin "2") (pintype "passive"))
    )

    (net (name "GND")
      (node (ref "PS1")   (pin "4") (pintype "output"))
      (node (ref "U1")    (pin "3") (pintype "passive"))
      (node (ref "C1")    (pin "2") (pintype "passive"))
      (node (ref "C2")    (pin "2") (pintype "passive"))
      (node (ref "C3")    (pin "2") (pintype "passive"))
      (node (ref "C4")    (pin "2") (pintype "passive"))
      (node (ref "C5")    (pin "2") (pintype "passive"))
      (node (ref "C6")    (pin "2") (pintype "passive"))
      (node (ref "Q1")    (pin "2") (pintype "passive"))
      (node (ref "SSR1")  (pin "4") (pintype "input"))
      (node (ref "RT1")   (pin "2") (pintype "passive"))
      (node (ref "J5")    (pin "2") (pintype "passive"))
      (node (ref "J4")    (pin "2") (pintype "passive"))
      (node (ref "FAN1")  (pin "2") (pintype "passive"))
      (node (ref "J6")    (pin "2") (pintype "passive"))
      (node (ref "LCD1")  (pin "2") (pintype "power_in"))
      (node (ref "J7")    (pin "2") (pintype "passive"))
      (node (ref "J8")    (pin "1") (pintype "passive"))
      (node (ref "U2")    (pin "1") (pintype "power_in"))
      (node (ref "D1")    (pin "1") (pintype "passive"))
      (node (ref "C8")    (pin "2") (pintype "passive"))
    )

    ;; ── SSR drive circuit ────────────────────────────────────────

    (net (name "SSR_CTRL_P")
      (node (ref "R1")    (pin "2") (pintype "passive"))
      (node (ref "Q1")    (pin "3") (pintype "passive"))
      (node (ref "D1")    (pin "2") (pintype "passive"))
      (node (ref "SSR1")  (pin "3") (pintype "input"))
    )

    (net (name "NPN_BASE")
      (node (ref "R2")    (pin "2") (pintype "passive"))
      (node (ref "Q1")    (pin "1") (pintype "input"))
    )

    (net (name "GPIO4_SSR_EN")
      (node (ref "R2")    (pin "1") (pintype "passive"))
      (node (ref "U2")    (pin "10") (pintype "bidirectional"))
    )

    ;; ── Plate NTC circuit ────────────────────────────────────────

    (net (name "NTC_PLATE_MID")
      (node (ref "R3")    (pin "2") (pintype "passive"))
      (node (ref "RT1")   (pin "1") (pintype "passive"))
      (node (ref "R7")    (pin "1") (pintype "passive"))
      (node (ref "C5")    (pin "1") (pintype "passive"))
    )

    (net (name "GPIO1_ADC_PLATE")
      (node (ref "R7")    (pin "2") (pintype "passive"))
      (node (ref "U2")    (pin "4") (pintype "bidirectional"))
    )

    ;; ── Liquid NTC circuit ───────────────────────────────────────

    (net (name "NTC_LIQUID_MID")
      (node (ref "R4")    (pin "2") (pintype "passive"))
      (node (ref "J5")    (pin "1") (pintype "passive"))
      (node (ref "R8")    (pin "1") (pintype "passive"))
      (node (ref "C6")    (pin "1") (pintype "passive"))
    )

    (net (name "GPIO2_ADC_LIQUID")
      (node (ref "R8")    (pin "2") (pintype "passive"))
      (node (ref "U2")    (pin "5") (pintype "bidirectional"))
    )

    ;; ── KSD301 NO warning signal ─────────────────────────────────

    (net (name "KSD_WARN_NET")
      (node (ref "R5")    (pin "2") (pintype "passive"))
      (node (ref "J4")    (pin "1") (pintype "passive"))
      (node (ref "U2")    (pin "11") (pintype "bidirectional"))
    )

    ;; ── SPI display signals ──────────────────────────────────────

    (net (name "SPI_SCK")
      (node (ref "U2")    (pin "18") (pintype "output"))
      (node (ref "LCD1")  (pin "3") (pintype "input"))
      (node (ref "J7")    (pin "3") (pintype "passive"))
    )

    (net (name "SPI_MOSI")
      (node (ref "U2")    (pin "17") (pintype "output"))
      (node (ref "LCD1")  (pin "4") (pintype "input"))
      (node (ref "J7")    (pin "4") (pintype "passive"))
    )

    (net (name "SPI_CS")
      (node (ref "U2")    (pin "16") (pintype "output"))
      (node (ref "LCD1")  (pin "5") (pintype "input"))
      (node (ref "J7")    (pin "5") (pintype "passive"))
    )

    (net (name "SPI_DC")
      (node (ref "U2")    (pin "15") (pintype "output"))
      (node (ref "LCD1")  (pin "6") (pintype "input"))
      (node (ref "J7")    (pin "6") (pintype "passive"))
    )

    (net (name "SPI_RST")
      (node (ref "U2")    (pin "14") (pintype "output"))
      (node (ref "LCD1")  (pin "7") (pintype "input"))
      (node (ref "J7")    (pin "7") (pintype "passive"))
    )

    (net (name "DISP_BL")
      (node (ref "U2")    (pin "13") (pintype "output"))
      (node (ref "R6")    (pin "1") (pintype "passive"))
    )

    (net (name "DISP_BL_OUT")
      (node (ref "R6")    (pin "2") (pintype "passive"))
      (node (ref "LCD1")  (pin "8") (pintype "input"))
      (node (ref "J7")    (pin "8") (pintype "passive"))
    )

    ;; ── Debug UART ───────────────────────────────────────────────

    (net (name "UART_TX")
      (node (ref "U2")    (pin "38") (pintype "output"))
      (node (ref "J8")    (pin "3") (pintype "passive"))
    )

    (net (name "UART_RX")
      (node (ref "U2")    (pin "37") (pintype "input"))
      (node (ref "J8")    (pin "4") (pintype "passive"))
    )

  ) ;; end nets

) ;; end net-list
